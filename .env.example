# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# HuggingFace token — required for gated models (e.g. fishaudio/openaudio-s1-mini)
# Get yours at: huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional training overrides (uncomment to use)
# BATCH_SIZE=16
# NUM_EPOCHS=100
# NUM_WORKERS=8
# SPEAKER_NAME=my_voice
